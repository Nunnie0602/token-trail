# Token Trail — Docker 環境變數範例
# 複製為 .env 後依需求調整: cp .env.example .env

# --- 服務連線 ---
REDIS_URL=redis://redis:6379/0
OLLAMA_HOST=http://ollama:11434
LOG_LEVEL=INFO

# --- 對外埠號 ---
API_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379
OLLAMA_PORT=11434
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# --- 前端 ---
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# --- Grafana（observability profile）---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Compose Profiles ---
# 預設僅啟動 frontend + backend + redis
# Phase 3 AI:       COMPOSE_PROFILES=ai
# Phase 4 監控:     COMPOSE_PROFILES=observability
# 全棧:             COMPOSE_PROFILES=ai,observability
COMPOSE_PROFILES=
